APP_NAME=CSV Import Fixer API
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=csv_import_fixer
POSTGRES_PASSWORD=csv_import_fixer
POSTGRES_DB=csv_import_fixer
DATABASE_URL=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MAX_UPLOAD_SIZE_BYTES=10485760
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/data/storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET_NAME=csv-import-fixer
S3_USE_SSL=false

ANALYSIS_PREVIEW_ROWS=10
ANALYSIS_SAMPLE_LINES=50
TRANSFORM_PHONE_WARNING_IS_ERROR=false
IMPORT_REQUIRES_TEMPLATE=false

LOG_LEVEL=INFO
AUTH_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_MINUTE=300
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_REDIS_TIMEOUT_MS=250
METRICS_ENABLED=true
READINESS_DB_TIMEOUT_MS=500
READINESS_REDIS_TIMEOUT_MS=500
READINESS_STORAGE_TIMEOUT_MS=500

# Optional OpenRouter mapping assist (off by default)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=https://csvora.local
OPENROUTER_APP_TITLE=Csvora API
AI_MAPPING_ENABLED=false
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
